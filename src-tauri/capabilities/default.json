{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for BeardGit",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-title",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "core:webview:allow-set-webview-zoom"
  ]
}
